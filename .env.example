# Copy this file to .env and fill in the values. .env is gitignored.

# ── LLM provider keys ────────────────────────────────────────────────
# Only the providers you actually use need a key. `echo` works with
# nothing set (deterministic test double, no API call).
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=

# ── FastAPI / runtime configuration (api/main.py reads these) ───────
# Vector store backend: "chroma" (in-process) or "qdrant".
JAI_STORE_BACKEND=chroma
# Where Chroma persists its SQLite + HNSW index (only used when chroma).
JAI_STORE_PATH=./data/chroma
# Where to find Qdrant (only used when qdrant).
# Pick ONE: HTTP URL (separate server) OR a local path (embedded file mode).
JAI_QDRANT_URL=http://localhost:6333
# JAI_QDRANT_PATH=./qdrant_data
# CSV that backs the structured DuckDB table. Anything matching
# (From, To, Subject, Date, Body, Company, Role) shape works.
JAI_STRUCTURED_CSV=./data/synthetic/demo.csv
# Streamlit talks to the API over this URL.
JAI_API_URL=http://localhost:8000
# Set to "1" in production demos — hides sidebar knobs that could
# burn money and surfaces a synthetic-data banner.
# JAI_DEMO_MODE=1

# ── scripts/filter_acks.py (only needed if you have your own Gmail exports) ──
# JAI_GMAIL_DIR=/path/to/your/gmail/csvs
