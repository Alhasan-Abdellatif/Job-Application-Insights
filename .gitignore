# ── Python ─────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
*.egg
.eggs/
.installed.cfg
build/
dist/

# ── Virtual envs ──────────────────────────────────────
.venv/
venv/
env/
ENV/

# ── Tooling caches ────────────────────────────────────
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
coverage.xml
htmlcov/
.tox/

# ── Notebooks ─────────────────────────────────────────
.ipynb_checkpoints/

# ── Environment / secrets ─────────────────────────────
.env
.env.local
.env.*.local

# ── Data — NEVER commit personal email data ───────────
data/raw/
data/processed/
data/embeddings/
*.mbox
*.csv
evals/golden_set_review.md
evals/retrieval_review.md
!evals/golden_set.jsonl
# personal-email-derived subset — not for git
data/synthetic/ack_only.csv
# anything else under data/synthetic/ is fair game (synthetic test data)
!data/synthetic/*.jsonl
!data/synthetic/*.json
# demo.csv is templated/fictional, generated by scripts/build_synthetic_demo.py.
# Safe to ship — the Modal deployment loads it into the container image.
!data/synthetic/demo.csv

# ── Vector store ──────────────────────────────────────
.chroma/
data/chroma/
qdrant_storage/

# ── OS / IDE ──────────────────────────────────────────
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp
*.swo

# ── Logs ──────────────────────────────────────────────
*.log
logs/

# ── R history (stray files from R-side tooling) ──────
.Rhistory
.RData
.RDataTmp
